# LiNT-II service environment — TEMPLATE.
# Copy to /etc/lint-ii/lint-ii.env, fill in MISTRAL_API_KEY, then:
#   chown root:lint /etc/lint-ii/lint-ii.env && chmod 640 /etc/lint-ii/lint-ii.env
# NEVER commit the real key. This .example file holds only a placeholder.

# --- LLM provider -----------------------------------------------------------
LINT_PROVIDER=mistral
LINT_MODEL=mistral-large-latest
MISTRAL_API_KEY=REPLACE_WITH_YOUR_MISTRAL_KEY

# --- Logging ----------------------------------------------------------------
# Linux log location (the code default is the macOS ~/Library/Logs path).
LINT_II_LOG_PATH=/var/log/lint-ii/app.log
# INFO keeps timings without logging user text / model responses. Use DEBUG
# only for local debugging, never in the public deployment.
LINT_II_LOG_LEVEL=INFO

# --- Concurrency (optional; shown with their defaults) ----------------------
# Concurrent LLM analyses. The ceiling is Mistral's rate limit (~75 req/min),
# NOT the host, so raising this past ~3 draws 429s from Mistral unless your plan
# allows more throughput.
LINT_II_ANALYSIS_WORKERS=3
# Concurrent pandoc/pdftotext conversions + spaCy-only passes. A many-core box
# can raise this comfortably.
LINT_II_GENERAL_WORKERS=8
# Flood guard: reject /analyze with 429 once this many jobs are already pending.
LINT_II_MAX_PENDING_JOBS=12
